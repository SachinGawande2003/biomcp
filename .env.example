# ─────────────────────────────────────────────────────────
# BioMCP Environment Variables
# ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in values as needed.

# NCBI API key — get one free at https://www.ncbi.nlm.nih.gov/account/
# Increases NCBI rate limit from 3 req/s → 10 req/s
# NCBI_API_KEY=3325080d82d285ffc106d54008fc8088c408

# NVIDIA Boltz-2 API key — for protein structure prediction
# Get free key at: https://build.nvidia.com/mit/boltz2
# NVIDIA_BOLTZ2_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NVIDIA Evo2-40B API key — for DNA sequence generation
# Get free key at: https://build.nvidia.com/arc/evo2-40b
# NVIDIA_EVO2_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional shared fallback key for both NVIDIA integrations
# NVIDIA_NIM_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# BioGRID API key — for protein-protein interaction queries
# Get free key at: https://webservice.thebiogrid.org/
# Increases result limits and removes throttling
# BIOGRID_API_KEY=12c5a31b52e7f1feb1be8018138a37eb

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
# BIOMCP_LOG_LEVEL=INFO

# ─────────────────────────────────────────────────
# HTTP Server Configuration (Remote MCP Support)
# ─────────────────────────────────────────────────
# Set to "http" to enable remote connections via SSE
# BIOMCP_TRANSPORT=stdio

# Port for HTTP server (default: 8080)
# BIOMCP_HTTP_PORT=8080
