# ---------------------------------------------------------
# BioMCP environment variables
# ---------------------------------------------------------
# Copy this file to .env and fill in only the values you need.

# NCBI API key - get one free at https://www.ncbi.nlm.nih.gov/account/
# Increases NCBI rate limit from 3 req/s to 10 req/s
# NCBI_API_KEY=your_ncbi_api_key_here

# NVIDIA Boltz-2 API key - for protein structure prediction
# Get a key at https://build.nvidia.com/mit/boltz2
# NVIDIA_BOLTZ2_API_KEY=your_nvidia_boltz2_api_key_here

# NVIDIA Evo2-40B API key - for DNA sequence generation
# Get a key at https://build.nvidia.com/arc/evo2-40b
# NVIDIA_EVO2_API_KEY=your_nvidia_evo2_api_key_here

# Optional shared fallback key for both NVIDIA integrations
# NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key_here

# BioGRID API key - for protein-protein interaction queries
# Get one free at https://webservice.thebiogrid.org/
# Removes throttling and increases result limits
# BIOGRID_API_KEY=your_biogrid_api_key_here

# Anthropic API key - enables optional Claude synthesis for multi-omics reports
# Get one at https://console.anthropic.com/
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Enable or disable the Claude synthesis layer for multi-omics reports
# BIOMCP_ENABLE_CLAUDE_SYNTHESIS=1

# Optional override for the Claude synthesis model
# BIOMCP_CLAUDE_SYNTHESIS_MODEL=claude-sonnet-4-20250514

# Optional token cap for the generated synthesis
# BIOMCP_CLAUDE_SYNTHESIS_MAX_TOKENS=700

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
# BIOMCP_LOG_LEVEL=INFO

# ---------------------------------------------------------
# HTTP server configuration (remote MCP support)
# ---------------------------------------------------------
# Set to "http" to enable remote connections via SSE
# BIOMCP_TRANSPORT=stdio

# Port for HTTP server (default: 8080)
# BIOMCP_HTTP_PORT=8080

# Optional public website URL and icon URL advertised to MCP clients
# BIOMCP_WEBSITE_URL=https://heuris-biomcp.onrender.com
# BIOMCP_ICON_URL=https://heuris-biomcp.onrender.com/logo.png

# Hosted auth toggle. Enable for Anthropic-style authenticated remote connectors.
# BIOMCP_AUTH_ENABLED=1

# Enable OAuth 2.1 PKCE metadata and token endpoints when auth is enabled.
# BIOMCP_OAUTH_ENABLED=1

# Optional: auto-approve OAuth consent for a single trusted user/deployment.
# BIOMCP_OAUTH_AUTO_APPROVE=0

# OAuth subject to attach to approved tokens.
# BIOMCP_OAUTH_DEFAULT_SUBJECT=heuris-biomcp-user

# Optional dynamic client store path for OAuth registrations.
# BIOMCP_AUTH_STORE_FILE=.biomcp_oauth_clients.json

# Optional machine-to-machine API keys in key_id:secret format, comma-separated.
# BIOMCP_API_KEYS=primary:replace_with_a_long_random_secret

# Per-key rate-limit settings for API key auth.
# BIOMCP_API_KEY_RATE_LIMIT_REQUESTS=600
# BIOMCP_API_KEY_RATE_LIMIT_WINDOW_SECONDS=60

# Browser origins allowed for hosted HTTP access.
# BIOMCP_CORS_ALLOW_ORIGINS=https://claude.ai,https://chatgpt.com

# Global and authenticated HTTP rate-limit settings.
# BIOMCP_HTTP_RATE_LIMIT_ENABLED=1
# BIOMCP_HTTP_RATE_LIMIT_REQUESTS=120
# BIOMCP_HTTP_RATE_LIMIT_WINDOW_SECONDS=60
# BIOMCP_HTTP_AUTH_RATE_LIMIT_REQUESTS=600
# BIOMCP_HTTP_AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# Durable directory for saved sessions and literature watches.
# Important: on Render free tier, local disk is ephemeral unless this points to persistent storage.
# BIOMCP_SESSION_STORE_DIR=/var/data/biomcp-sessions

# Background cache warming in hosted mode.
# BIOMCP_CACHE_WARMING=auto
# BIOMCP_CACHE_WARM_GENE_LIMIT=20
# BIOMCP_CACHE_WARM_CONCURRENCY=4
